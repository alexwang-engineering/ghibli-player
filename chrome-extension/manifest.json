{
  "manifest_version": 3,
  "name": "Ghibli 视频下载器",
  "version": "1.0.0",
  "description": "像龙猫一样捕获网页中的视频，精准识别 MP4·HLS·DASH 等格式 🌿",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ghibli 视频下载器 🌿"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
